# --- LLM (OpenAI) ---
OPENAI_API_KEY=sk-...
MODEL_PLANNER=gpt-4o-mini
MODEL_AGENT=gpt-4o-mini
MODEL_SYNTHESIZER=gpt-4o

# --- CRM ---
# `stub` for offline dev / evals, `hubspot` for production
CRM_PROVIDER=stub
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_TIMEOUT_SECONDS=5

# --- Database ---
# Local SQLite by default; swap to postgresql+asyncpg://... for v2
DB_URL=sqlite+aiosqlite:///./data/meridian.db

# --- App ---
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000

# --- Observability (optional) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=meridian
LANGCHAIN_TRACING_V2=false
